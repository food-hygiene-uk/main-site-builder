{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "description": "Prevent updates that can be unpublished.",
      "matchDatasources": ["npm"],
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Disable updates for new managers.",
      "matchManagers": ["/.*/"],
      "enabled": false
    },
    {
      "description": "Explictly disable updates we know we don't want.",
      "matchManagers": ["devcontainer", "github-actions", "npm"],
      "enabled": false
    },
    {
      "matchManagers": ["/.*/"],
      "description": "Wait for 7 days to approve updates. Matches Dependabot config.",
      "internalChecksFilter": "strict",
      "minimumReleaseAge": "7 days"
    },
    {
      "description": "Explictly enable updates for desired managers.",
      "matchManagers": ["deno"],
      "enabled": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^.deno-version$/"],
      "matchStrings": ["^(?<currentValue>\\d+\\.\\d+\\.\\d+)$"],
      "depNameTemplate": "denoland/deno",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.devcontainer/devcontainer\\.json$/"],
      "matchStrings": [
        "--build-arg=DENO_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "denoland/deno",
      "datasourceTemplate": "github-releases"
    }
  ]
}
